theme = light:Rose Pine Dawn,dark:Rose Pine Moon

font-size = 17
font-thicken = false
font-family = "TX-02-Variable"
font-family = "FiraCode Nerd Font"
font-style = "Regular Retina"
adjust-cell-width="-6%"
font-feature = +calt
font-feature = +ss02
font-variation = wght=450

background-opacity = 0.95
background-blur-radius = 30

macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
title = 👻
shell-integration = none
mouse-scroll-multiplier = 0.4

keybind = cmd+h=goto_split:left
keybind = cmd+l=goto_split:right
keybind = cmd+k=goto_split:up
keybind = cmd+j=goto_split:down
keybind = shift+enter=text:\x1b\r
